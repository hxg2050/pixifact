  "logicGraph": {
    "version": 1,
    "type": "pixifact.logicGraph",
    "flows": [
      {
        "id": "flow-startBattle",
        "action": "startBattle",
        "name": "Start Battle",
        "description": "进入战斗并隐藏开始按钮。",
        "steps": [
          {
            "id": "markBattleStarted",
            "type": "setState",
            "path": "battle.started",
            "value": {
              "kind": "const",
              "value": true
            }
          },
          {
            "id": "hideStartButton",
            "type": "setNodeVisible",
            "node": "startBattleButton",
            "visible": false
          },
          {
            "id": "notifyBattleStarted",
            "type": "comment",
            "text": "Game code should spawn enemies and start the battle loop."
          }
        ]
      },
      {
        "id": "flow-openInventory",
        "action": "openInventory",
        "name": "Open Inventory",
        "description": "标记背包打开状态。",
        "steps": [
          {
            "id": "markInventoryOpen",
            "type": "setState",
            "path": "inventory.open",
            "value": {
              "kind": "const",
              "value": true
            }
          },
          {
            "id": "showInventoryHint",
            "type": "comment",
            "text": "The next editor step can generate an inventory panel bound to this action."
          }
        ]
      },
      {
        "id": "flow-castSkill",
        "action": "castSkill",
        "name": "Cast Skill",
        "description": "释放技能动作入口。",
        "steps": [
          {
            "id": "rememberSkill",
            "type": "setState",
            "path": "skill.lastCastAt",
            "value": {
              "kind": "const",
              "value": "runtime-now"
            }
          },
          {
            "id": "emitSkillComment",
            "type": "comment",
            "text": "Use payload.skill in game code when the runtime action dispatch includes a skill name."
          }
        ]
      }
    ]
  },
