<Scene name="MainMenu" script="../src/scenes/MainMenu.ts" class="MainMenu" width="960" height="540">
  <Panel id="settingsPanel" scene="scenes/Panel.scene" x="220" y="118" title="Scene Compiler Demo">
    <Text slot="content" id="bodyText" text="Button and Panel are independent Scene scripts. Panel exposes slots; Button exposes props and click." x="0" y="0" fontSize="18" fill="#c8d7f2" />
    <Button slot="footer" id="startButton" scene="scenes/Button.scene" label="Start" @click="startGame">
      <Graphics slot="icon" id="playIcon" shape="roundRect" width="18" height="18" radius="4" fill="#ffffff" />
    </Button>
  </Panel>
</Scene>
