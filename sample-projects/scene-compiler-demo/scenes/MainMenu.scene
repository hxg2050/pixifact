<Scene name="MainMenu" script="../src/scenes/MainMenu.ts" class="MainMenu">
  <Container key="root" width="960" height="540">
    <Panel key="settingsPanel" scene="scenes/Panel.scene" x="220" y="118" title="Scene Compiler Demo">
      <Text slot="default" key="bodyText" text="Button and Panel are independent Scene scripts. Panel exposes slots; Button exposes props and click." x="0" y="0" fontSize="18" fill="#c8d7f2" />
      <Button slot="footer" key="startButton" scene="scenes/Button.scene" label="Start" @click="startGame">
        <Graphics slot="icon" key="playIcon" shape="roundRect" width="18" height="18" radius="4" fill="#ffffff" />
      </Button>
    </Panel>
  </Container>
</Scene>
