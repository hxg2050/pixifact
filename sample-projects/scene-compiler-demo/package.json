{
  "name": "pixifact-scene-compiler-demo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "compile:scenes": "bun scripts/compile-scenes.ts",
    "dev": "bun run compile:scenes && vite . --host 127.0.0.1 --port 5175 --strictPort",
    "build": "bun run compile:scenes && vite build . --config vite.config.ts"
  },
  "dependencies": {
    "pixi.js": "8.18.1",
    "pixifact": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.3.3",
    "vite": "^8.0.10"
  }
}
