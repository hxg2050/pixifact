{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Node",
    "strict": true,
    "experimentalDecorators": true,
    "useDefineForClassFields": true,
    "lib": ["ESNext", "DOM"],
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "pixifact": ["../../packages/pixifact/src/index.ts"],
      "pixifact/*": ["../../packages/pixifact/src/*"]
    }
  },
  "include": ["src/**/*.ts"]
}
