<Scene name="InventoryPanel" width="690" height="650">
  <NineImage id="panelBack" texture="assets/ui/panel-9.svg" left="0" right="0" top="0" bottom="0" leftWidth="30" rightWidth="30" topHeight="30" bottomHeight="30" />
  <Text id="titleText" text="探险背包" x="42" y="34" fontSize="34" fontWeight="700" fill="#fff3cf" />
  <Text id="capacityText" text="18 / 32" x="542" y="43" fontSize="24" fontWeight="700" fill="#ffdb84" />
  <Rect id="divider" x="42" y="88" width="606" height="2" fillColor="#f2ce76" fillAlpha="0.38" />
  <VBoxContainer id="slotRows" x="42" y="126" width="606" height="372" gap="18">
    <HBoxContainer id="slotRowA" width="606" height="112" gap="18" justify="space-between">
      <ItemSlot id="firstSlot" scene="./ItemSlot.scene" itemName="治疗药水" quantity="6" selected="true" />
      <ItemSlot id="secondSlot" scene="./ItemSlot.scene" itemName="月石碎片" quantity="12" />
      <ItemSlot id="thirdSlot" scene="./ItemSlot.scene" itemName="古旧钥匙" quantity="1" />
      <ItemSlot id="fourthSlot" scene="./ItemSlot.scene" itemName="火把" quantity="4" />
      <ItemSlot id="fifthSlot" scene="./ItemSlot.scene" itemName="绷带" quantity="9" />
    </HBoxContainer>
    <HBoxContainer id="slotRowB" width="606" height="112" gap="18" justify="space-between">
      <ItemSlot id="sixthSlot" scene="./ItemSlot.scene" itemName="短剑" quantity="1" />
      <ItemSlot id="seventhSlot" scene="./ItemSlot.scene" itemName="护符" quantity="2" />
      <ItemSlot id="eighthSlot" scene="./ItemSlot.scene" itemName="蓝莓" quantity="15" />
      <ItemSlot id="ninthSlot" scene="./ItemSlot.scene" itemName="卷轴" quantity="3" />
      <ItemSlot id="tenthSlot" scene="./ItemSlot.scene" itemName="宝石" quantity="5" />
    </HBoxContainer>
    <HBoxContainer id="slotRowC" width="606" height="112" gap="18" justify="space-between">
      <ItemSlot id="eleventhSlot" scene="./ItemSlot.scene" itemName="皮革" quantity="8" />
      <ItemSlot id="twelfthSlot" scene="./ItemSlot.scene" itemName="银币袋" quantity="2" />
      <ItemSlot id="thirteenthSlot" scene="./ItemSlot.scene" itemName="空瓶" quantity="7" />
      <ItemSlot id="fourteenthSlot" scene="./ItemSlot.scene" itemName="罗盘" quantity="1" />
      <ItemSlot id="fifteenthSlot" scene="./ItemSlot.scene" itemName="羽毛" quantity="6" />
    </HBoxContainer>
  </VBoxContainer>
  <Rect id="hintBack" x="42" y="528" width="386" height="70" fillColor="#101927" fillAlpha="0.88" strokeColor="#6f8aa4" strokeAlpha="0.36" strokeWidth="1" radius="18" />
  <Text id="hintTitle" text="选中：治疗药水" x="64" y="544" fontSize="20" fontWeight="700" fill="#d8e6f3" />
  <Text id="hintText" text="恢复 120 点生命。适合在遗迹深处使用。" x="64" y="574" fontSize="16" fill="#a9c6d8" />
  <Button id="sortButton" scene="./Button.scene" x="462" y="532" width="168" height="60" label="整理" tone="ghost">
    <Image slot="icon" id="sortIcon" texture="assets/icons/bag.svg" width="38" height="38" fit="contain" />
  </Button>
</Scene>
