<Scene name="Hud" width="720" height="1280">
  <Graphics id="topBand" shape="roundRect" x="32" y="32" width="656" height="158" radius="24" fill="#111827" fillAlpha="0.82" strokeColor="#38bdf8" strokeWidth="2" strokeAlpha="0.65" />
  <FlexLayout id="topStats" scene="./FlexLayout.scene" x="60" y="58" width="598" height="112" direction="row" align="start" justify="space-between">
    <FlexItem scene="./FlexItem.scene" basis="180">
      <Text id="scoreLabel" text="SCORE" fontSize="18" fontWeight="700" fill="#93c5fd" />
      <Text id="scoreText" text="000000" y="28" fontSize="42" fontWeight="700" fill="#f8fafc" />
    </FlexItem>
    <FlexItem scene="./FlexItem.scene" basis="154">
      <Text id="waveLabel" text="WAVE" fontSize="18" fontWeight="700" fill="#c4b5fd" />
      <Text id="waveText" text="01" y="28" fontSize="42" fontWeight="700" fill="#f8fafc" />
      <Text id="timeLabel" text="TIME" y="78" fontSize="16" fontWeight="700" fill="#94a3b8" />
      <Text id="timeText" text="00:00" x="56" y="76" fontSize="22" fontWeight="700" fill="#e2e8f0" />
    </FlexItem>
  </FlexLayout>
  <FlexLayout id="hpRow" scene="./FlexLayout.scene" x="60" y="214" width="598" height="32" direction="row" align="center" gap="16">
    <Text id="hpLabel" text="HP" fontSize="20" fontWeight="700" fill="#fca5a5" />
    <FlexItem scene="./FlexItem.scene" grow="1" minWidth="548">
      <Graphics id="hpBack" shape="roundRect" width="548" height="28" radius="14" fill="#1f2937" />
      <Graphics id="hpFill" shape="roundRect" width="548" height="28" radius="14" fill="#ef4444" />
    </FlexItem>
  </FlexLayout>
  <FlexLayout id="energyRow" scene="./FlexLayout.scene" x="60" y="266" width="598" height="28" direction="row" align="center" gap="16">
    <Text id="energyLabel" text="ENERGY" fontSize="18" fontWeight="700" fill="#fde68a" />
    <FlexItem scene="./FlexItem.scene" grow="1" minWidth="500">
      <Graphics id="energyBack" shape="roundRect" width="500" height="20" radius="10" fill="#1f2937" />
      <Graphics id="energyFill" shape="roundRect" width="500" height="20" radius="10" fill="#facc15" />
    </FlexItem>
  </FlexLayout>
  <FlexLayout id="hintRow" scene="./FlexLayout.scene" x="60" y="1200" width="600" height="40" direction="row" align="center">
    <Text id="hintText" text="Move: WASD / arrows" fontSize="22" fontWeight="700" fill="#bae6fd" />
  </FlexLayout>
</Scene>
