{
  "version": 1,
  "type": "scene",
  "name": "MainMenu",
  "root": {
    "kind": "container",
    "name": "MainMenu",
    "key": "mainMenuRoot",
    "transform": {
      "width": 960,
      "height": 540
    },
    "children": [
      {
        "kind": "shape",
        "key": "menuBackdrop",
        "name": "菜单背景",
        "transform": {
          "width": 960,
          "height": 540
        },
        "shape": {
          "type": "rect",
          "color": 789520
        }
      },
      {
        "kind": "text",
        "key": "menuTitle",
        "name": "标题",
        "transform": {
          "x": 284,
          "y": 150,
          "width": 420,
          "height": 58
        },
        "text": {
          "value": "SPACE HUD",
          "color": 12320767,
          "fontSize": 42,
          "fontWeight": "900",
          "center": true
        }
      },
      {
        "kind": "container",
        "key": "startButton",
        "role": "button",
        "name": "开始按钮",
        "transform": {
          "x": 380,
          "y": 260,
          "width": 200,
          "height": 52
        },
        "children": [
          {
            "kind": "shape",
            "key": "startButtonBg",
            "name": "按钮背景",
            "transform": {
              "width": 200,
              "height": 52
            },
            "shape": {
              "type": "roundedRect",
              "color": 35839,
              "radius": 14,
              "strokeColor": 12320767,
              "strokeWidth": 1
            }
          },
          {
            "kind": "text",
            "key": "startButtonLabel",
            "name": "按钮文字",
            "transform": {
              "width": 200,
              "height": 52
            },
            "text": {
              "value": "START",
              "color": 16777215,
              "fontSize": 22,
              "fontWeight": "900",
              "center": true
            }
          }
        ]
      }
    ]
  }
}
