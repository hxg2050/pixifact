{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Pixifact Editor",
  "version": "0.1.3",
  "identifier": "com.pixifact.editor",
  "build": {
    "beforeDevCommand": {
      "script": "bunx --no-install vite . --config ../../vite.config.ts --host 127.0.0.1 --port 3173 --strictPort",
      "cwd": "../"
    },
    "devUrl": "http://127.0.0.1:3173",
    "beforeBuildCommand": {
      "script": "bun run editor:frontend:build",
      "cwd": "../../../"
    },
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Pixifact Editor",
        "width": 1440,
        "height": 900,
        "minWidth": 1100,
        "minHeight": 720,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
