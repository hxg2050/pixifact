{
  "name": "pixifact-workspace",
  "version": "0.1.3",
  "description": "Pixifact workspace for the Pixif framework, editor, and MCP tooling.",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "packageManager": "bun@1.3.13",
  "type": "module",
  "files": [
    "skills/",
    "scripts/install-skills.mjs"
  ],
  "bin": {
    "pixifact-skills": "scripts/install-skills.mjs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hxg2050/pixifact.git"
  },
  "keywords": [
    "ai-editor",
    "game-editor",
    "pixijs",
    "scene",
    "runtime"
  ],
  "author": "youxia <243802688@qq.com>",
  "license": "MIT",
  "scripts": {
    "build": "cd packages/pixifact && bun run build",
    "desktop": "VITE_PIXIFACT_PROJECT_ROOT=$PWD bunx --no-install tauri dev --config apps/editor/src-tauri/tauri.conf.json",
    "desktop:build": "VITE_PIXIFACT_PROJECT_ROOT=$PWD bunx --no-install tauri build --config apps/editor/src-tauri/tauri.conf.json",
    "editor": "VITE_PIXIFACT_PROJECT_ROOT=$PWD bunx --no-install vite apps/editor --config vite.config.ts",
    "editor:ai": "bun run build && bun apps/editor/src/mock/mock-ai-server.mjs",
    "editor:gateway": "bun apps/editor/src/gateway/ai-gateway-adapter.mjs",
    "editor:mcp": "bun packages/pixifact-mcp/src/pixifact-mcp-server.ts",
    "editor:build": "VITE_PIXIFACT_PROJECT_ROOT=$PWD bunx --no-install vite build apps/editor --config vite.config.ts",
    "editor:dockview": "bunx --no-install vite apps/editor-dockview-prototype --config vite.config.ts",
    "editor:e2e": "bunx --no-install playwright test",
    "example": "bunx --no-install vite examples/basic --config vite.config.ts",
    "example:build": "bunx --no-install vite build examples/basic --config vite.config.ts",
    "skills:install": "bun scripts/install-skills.mjs --replace",
    "test": "bunx --no-install vitest run",
    "test:watch": "bunx --no-install vitest"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@rollup/plugin-typescript": "^11.1.6",
    "@tauri-apps/cli": "2.11.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "happy-dom": "^20.9.0",
    "pixi.js": "8.18.1",
    "rollup": "^4.9.4",
    "tslib": "^2.6.2",
    "typescript": "^5.3.3",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "@math.gl/core": "^4.0.1",
    "dockview": "^6.0.1",
    "eventemitter3": "^5.0.1",
    "lucide-react": "^1.14.0",
    "react": "^19.2.5",
    "react-aria-components": "^1.17.0",
    "react-dom": "^19.2.5",
    "zod": "^4.4.3",
    "zustand": "^5.0.12"
  }
}
