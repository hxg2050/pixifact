{
  "name": "pixifact",
  "version": "0.1.3",
  "description": "Editor-first AI game UI authoring tool with a PixiJS runtime foundation.",
  "packageManager": "bun@1.3.13",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "type": "module",
  "files": [
    "dist/",
    "skills/",
    "scripts/install-skills.mjs"
  ],
  "bin": {
    "pixifact-skills": "scripts/install-skills.mjs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hxg2050/pixifact.git"
  },
  "keywords": [
    "ai-editor",
    "game-editor",
    "pixijs",
    "prefab",
    "runtime"
  ],
  "author": "youxia <243802688@qq.com>",
  "license": "MIT",
  "scripts": {
    "build": "bunx --no-install rollup -c",
    "editor": "VITE_PIXIFACT_PROJECT_ROOT=$PWD bunx --no-install vite apps/editor",
    "editor:ai": "bun run build && bun apps/editor/src/mock/mock-ai-server.mjs",
    "editor:gateway": "bun apps/editor/src/gateway/ai-gateway-adapter.mjs",
    "editor:build": "VITE_PIXIFACT_PROJECT_ROOT=$PWD bunx --no-install vite build apps/editor",
    "editor:dockview": "bunx --no-install vite apps/editor-dockview-prototype",
    "editor:e2e": "bunx --no-install playwright test",
    "example": "bunx --no-install vite examples/basic",
    "example:build": "bunx --no-install vite build examples/basic",
    "skills:install": "bun scripts/install-skills.mjs --replace",
    "test": "bunx --no-install vitest run",
    "test:watch": "bunx --no-install vitest"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./ui": {
      "types": "./dist/ui/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./editor": {
      "types": "./dist/editor/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./commands": {
      "types": "./dist/commands/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./prefab": {
      "types": "./dist/prefab/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@rollup/plugin-typescript": "^11.1.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "happy-dom": "^20.9.0",
    "pixi.js": "8.18.1",
    "rollup": "^4.9.4",
    "tslib": "^2.6.2",
    "typescript": "^5.3.3",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "@math.gl/core": "^4.0.1",
    "dockview": "^6.0.1",
    "eventemitter3": "^5.0.1",
    "lucide-react": "^1.14.0",
    "react": "^19.2.5",
    "react-aria-components": "^1.17.0",
    "react-dom": "^19.2.5",
    "zod": "^4.4.3",
    "zustand": "^5.0.12"
  },
  "peerDependencies": {
    "pixi.js": ">=8.3.0"
  }
}
